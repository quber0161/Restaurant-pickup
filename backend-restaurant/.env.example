# Copy this file to .env and fill in your values. Never commit .env to git.

# Database (MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/restaurant

# Auth
JWT_SECRET=your-jwt-secret-string
SUPERADMIN_EMAIL=your-superadmin@email.com
SUPERADMIN_PASSWORD=your-superadmin-password

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx

# Email (Gmail app password or SMTP credentials)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
TEST_EMAIL=optional-for-test-email-endpoint

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173
